---
import Layout from '../layouts/Layout.astro';
import Home from '../components/site/Home';

const skipPitch = import.meta.env.PUBLIC_SKIP_PITCH !== '0'; // template default: straight to the site
---

{true ? (
  <Layout
    title="Sample Bistro — Neighborhood Kitchen in Anytown, CA"
    description="Family-owned neighborhood kitchen in Anytown. Fresh, made-from-scratch food. Order online — ready in about 30 minutes."
    path="/"
  >
    <Home client:load />
  </Layout>
) : null}
